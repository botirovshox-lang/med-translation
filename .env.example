# Medical CAT Translator v5.5 - Environment Configuration
# Copy this file to .env and fill in with real values

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# OpenAI API
OPENAI_API_KEY=sk-...your-key-here...

# Google Cloud Translation
GOOGLE_TRANSLATE_API_KEY=your-google-key-here

# Anthropic API (for glossary engine)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Database (optional - defaults to SQLite)
DATABASE_URL=sqlite:///med_translation.db

# Streamlit Settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
